#!/bin/bash
# azure-ddns — dynamic DNS updater for Azure DNS (A + AAAA records).
#
# Reads credentials and record target from /etc/azure-ddns.env (mode 600,
# user-supplied). Detects current public IPv4/IPv6 via ipify, caches last
# pushed value, and PUTs CreateOrUpdate against the Azure Resource Manager
# API when either stack's IP has changed.
#
# Deps: bash curl jq (coreutils). Intended to run from a systemd timer +
# NetworkManager dispatcher hook; both are shipped alongside.

set -euo pipefail

ENV_FILE="${AZURE_DDNS_ENV:-/etc/azure-ddns.env}"
CACHE_DIR="${AZURE_DDNS_CACHE:-/var/lib/azure-ddns}"
TOKEN_CACHE="${AZURE_DDNS_TOKEN_CACHE:-/run/azure-ddns-token.json}"

log()  { printf 'azure-ddns: %s\n' "$*"; }
warn() { printf 'azure-ddns: WARN %s\n' "$*" >&2; }
die()  { printf 'azure-ddns: ERR %s\n' "$*" >&2; exit 1; }

# Pick an IPv6 GUA from the local host per AZURE_DDNS_IPV6_SELECT.
# Modes: slaac-stable (default), slaac-temporary, static, or a literal IPv6.
# Optional AZURE_DDNS_IPV6_IFACE scopes discovery to one interface.
# Filters to global unicast (2000::/3) only — excludes ULA, link-local, multicast.
# Tie-breaks by longest preferred lifetime. Empty stdout if nothing matches.
pick_ipv6() {
    local mode iface json type_filter
    mode="${AZURE_DDNS_IPV6_SELECT:-slaac-stable}"
    iface="${AZURE_DDNS_IPV6_IFACE:-}"

    case "$mode" in
        slaac-stable)
            type_filter='.dynamic==true and (.temporary // false)==false'
            ;;
        slaac-temporary)
            type_filter='(.temporary // false)==true'
            ;;
        static)
            type_filter='(.dynamic // false)==false and (.temporary // false)==false'
            ;;
        *:*)
            type_filter=''
            ;;
        *)
            die "AZURE_DDNS_IPV6_SELECT='$mode' invalid (expected: slaac-stable | slaac-temporary | static | <ipv6-literal>)"
            ;;
    esac

    local ip_args=(-j -6 addr show scope global)
    [[ -n "$iface" ]] && ip_args+=(dev "$iface")

    json=$(ip "${ip_args[@]}" 2>/dev/null) || return 0
    [[ -n "$json" && "$json" != "[]" ]] || return 0

    if [[ -n "$type_filter" ]]; then
        jq -r "
            [.[].addr_info[]
             | select(.family==\"inet6\")
             | select((.local | test(\"^[23]\")))
             | select($type_filter)
             | select((.deprecated // false)==false and (.tentative // false)==false)
             | [(.preferred_life_time // 0), .local]]
            | sort_by(.[0]) | reverse | .[0][1] // empty" <<<"$json"
    else
        local result
        result=$(jq -r --arg ip "$mode" '
            [.[].addr_info[]
             | select(.family=="inet6" and .local==$ip)
             | .local][0] // empty' <<<"$json")
        [[ -n "$result" ]] || warn "AZURE_DDNS_IPV6_SELECT='$mode' not found among host's global IPv6 addresses"
        printf '%s' "$result"
    fi
}

# Allow sourcing for unit tests; only run main flow when executed directly.
[[ "${BASH_SOURCE[0]}" != "$0" ]] && return 0

[[ -r "$ENV_FILE" ]] || die "$ENV_FILE not readable — see README for service-principal setup"
# shellcheck disable=SC1090
. "$ENV_FILE"

for v in AZ_TENANT_ID AZ_CLIENT_ID AZ_CLIENT_SECRET AZ_SUBSCRIPTION_ID AZ_RESOURCE_GROUP AZ_DNS_ZONE AZ_DNS_RECORD; do
    [[ -n "${!v:-}" ]] || die "$v is empty in $ENV_FILE"
done

mkdir -p "$CACHE_DIR"

# IPv4 needs ipify because hosts behind NAT can't see their public address
# locally; the v4-only hostname forces the stack so curl can't fall back to v6.
# IPv6 GUAs are routable directly, so we introspect the host instead — see
# pick_ipv6() above and AZURE_DDNS_IPV6_SELECT in the README.
# Either stack can be disabled via DDNS_DISABLE_IPV4 / DDNS_DISABLE_IPV6.
IPV4=""
IPV6=""
if [[ "${DDNS_DISABLE_IPV4:-0}" != "1" ]]; then
    IPV4=$(curl -4 -fsS --max-time 10 https://api.ipify.org 2>/dev/null || true)
fi
if [[ "${DDNS_DISABLE_IPV6:-0}" != "1" ]]; then
    IPV6=$(pick_ipv6 || true)
fi

if [[ -z "$IPV4" && -z "$IPV6" ]]; then
    if [[ "${DDNS_DISABLE_IPV4:-0}" == "1" && "${DDNS_DISABLE_IPV6:-0}" == "1" ]]; then
        die "Both DDNS_DISABLE_IPV4 and DDNS_DISABLE_IPV6 are set — nothing to do."
    fi
    warn "no public IP detected — network down? skipping."
    exit 0
fi

LAST_V4=$(cat "$CACHE_DIR/a.last" 2>/dev/null || true)
LAST_V6=$(cat "$CACHE_DIR/aaaa.last" 2>/dev/null || true)

# Short-circuit: nothing changed → no Azure call.
if [[ "$IPV4" == "$LAST_V4" && "$IPV6" == "$LAST_V6" ]]; then
    exit 0
fi

# JWT cache. Token is good ~1h; refresh if <60s remaining or cache absent.
TOKEN=""
if [[ -r "$TOKEN_CACHE" ]]; then
    EXP=$(jq -r '.expires_at // 0' "$TOKEN_CACHE" 2>/dev/null || echo 0)
    if (( EXP > $(date +%s) + 60 )); then
        TOKEN=$(jq -r '.access_token' "$TOKEN_CACHE")
    fi
fi

if [[ -z "$TOKEN" ]]; then
    log "minting new Azure access token..."
    # No -f: keep the body on 4xx so we can surface AAD's AADSTS error code.
    HTTP=$(curl -sS --max-time 15 -w $'\n%{http_code}' \
        -X POST "https://login.microsoftonline.com/${AZ_TENANT_ID}/oauth2/v2.0/token" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        --data-urlencode "grant_type=client_credentials" \
        --data-urlencode "client_id=${AZ_CLIENT_ID}" \
        --data-urlencode "client_secret=${AZ_CLIENT_SECRET}" \
        --data-urlencode "scope=https://management.azure.com/.default" 2>&1) \
        || die "token request failed (network/DNS): $HTTP"
    CODE="${HTTP##*$'\n'}"
    RESP="${HTTP%$'\n'*}"

    if [[ "$CODE" != "200" ]]; then
        DESC=$(echo "$RESP" | jq -r '.error_description // empty' 2>/dev/null || true)
        AADSTS=$(echo "$DESC" | grep -oE 'AADSTS[0-9]+' | head -1 || true)
        ROTATE="az ad sp credential reset --id ${AZ_CLIENT_ID} --years 2 --append"
        case "$AADSTS" in
            AADSTS7000222)
                die "Azure SP client secret has EXPIRED. Rotate with: $ROTATE — then update AZ_CLIENT_SECRET in $ENV_FILE and 'systemctl restart azure-ddns.service'. (--append keeps the old secret valid during cutover.) AAD: $DESC"
                ;;
            AADSTS7000215)
                die "Azure rejected AZ_CLIENT_SECRET as invalid. Check $ENV_FILE for typos/whitespace, or rotate: $ROTATE. AAD: $DESC"
                ;;
            AADSTS700016)
                die "Azure does not recognize AZ_CLIENT_ID=$AZ_CLIENT_ID in tenant $AZ_TENANT_ID. Verify both in $ENV_FILE. AAD: $DESC"
                ;;
            AADSTS90002)
                die "Azure tenant $AZ_TENANT_ID not found. Verify AZ_TENANT_ID in $ENV_FILE. AAD: $DESC"
                ;;
            "")
                die "token request HTTP $CODE (non-AAD response): $RESP"
                ;;
            *)
                die "token request rejected by Azure ($AADSTS): $DESC"
                ;;
        esac
    fi

    TOKEN=$(echo "$RESP" | jq -r '.access_token // empty')
    EXPIRES_IN=$(echo "$RESP" | jq -r '.expires_in // 3600')
    [[ -n "$TOKEN" ]] || die "token request returned HTTP 200 but empty access_token: $RESP"
    EXPIRES_AT=$(($(date +%s) + EXPIRES_IN))
    echo "$RESP" | jq ". + {\"expires_at\": $EXPIRES_AT}" > "$TOKEN_CACHE"
    chmod 600 "$TOKEN_CACHE"
fi

URL_BASE="https://management.azure.com/subscriptions/${AZ_SUBSCRIPTION_ID}/resourceGroups/${AZ_RESOURCE_GROUP}/providers/Microsoft.Network/dnsZones/${AZ_DNS_ZONE}"
API_VER="api-version=2018-05-01"
TTL="${AZ_DNS_TTL:-300}"

# PUT (CreateOrUpdate) — works whether the record exists or not. First run
# creates <record>.<zone> if the user hasn't pre-created it in Azure portal.
upsert() {
    local kind="$1" ip="$2" body
    if [[ "$kind" == "A" ]]; then
        body=$(jq -nc --arg ip "$ip" --argjson ttl "$TTL" \
            '{properties:{TTL:$ttl,ARecords:[{ipv4Address:$ip}]}}')
    else
        body=$(jq -nc --arg ip "$ip" --argjson ttl "$TTL" \
            '{properties:{TTL:$ttl,AAAARecords:[{ipv6Address:$ip}]}}')
    fi
    curl -fsS -X PUT \
        -H "Authorization: Bearer $TOKEN" \
        -H "Content-Type: application/json" \
        -d "$body" \
        "${URL_BASE}/${kind}/${AZ_DNS_RECORD}?${API_VER}" >/dev/null
}

if [[ -n "$IPV4" && "$IPV4" != "$LAST_V4" ]]; then
    upsert A "$IPV4" || die "Azure PUT A failed"
    echo "$IPV4" > "$CACHE_DIR/a.last"
    log "A    ${AZ_DNS_RECORD}.${AZ_DNS_ZONE} → $IPV4"
fi

if [[ -n "$IPV6" && "$IPV6" != "$LAST_V6" ]]; then
    upsert AAAA "$IPV6" || die "Azure PUT AAAA failed"
    echo "$IPV6" > "$CACHE_DIR/aaaa.last"
    log "AAAA ${AZ_DNS_RECORD}.${AZ_DNS_ZONE} → $IPV6"
fi
